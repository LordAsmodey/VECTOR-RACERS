{
  "name": "vector-racers",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0 <23"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "pnpm --filter @vector-racers/api test",
    "db:generate": "pnpm --filter @vector-racers/db exec prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "pnpm --filter @vector-racers/db exec prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "pnpm --filter @vector-racers/db exec prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "pnpm --filter @vector-racers/db exec prisma db seed --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
