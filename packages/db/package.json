{
  "name": "@vector-racers/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "dev": "prisma generate --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5433/vector_racers?schema=public} prisma validate --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vector-racers/config": "workspace:*",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
