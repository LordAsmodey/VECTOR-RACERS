# --- API (NestJS) ---
API_URL=http://localhost:3001
# apps/api uses process.env.PORT ?? 3000; set 3001 to match API_URL / NEXT_PUBLIC_API_URL
PORT=3001
NODE_ENV=development

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Docker Compose: postgres service (docker-compose.dev.yml) ---
# Must match DATABASE_URL below (same user, password, database name).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vector_racers

# --- Database (Prisma in packages/db) ---
# Use host port 5433 — docker-compose.dev.yml maps postgres to 5433 so another DB on 5432 is not touched.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vector_racers?schema=public

# --- Seed (packages/db prisma/seed.ts — TASK-005) ---
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=change-me-seed-password
# Optional; default seed_admin
# SEED_ADMIN_USERNAME=seed_admin

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256) — paths to PEM files or inline base64 in prod tooling ---
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/jwt-access-public.pem
JWT_ACCESS_PRIVATE_KEY_PATH=./keys/jwt-access-private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=./keys/jwt-refresh-public.pem
JWT_REFRESH_PRIVATE_KEY_PATH=./keys/jwt-refresh-private.pem

# --- CORS (comma-separated origins for Nest) ---
CORS_ORIGINS=http://localhost:3000

# --- Metrics / ops ---
METRICS_TOKEN=change-me-in-production

# --- Stripe (optional / post-MVP) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
