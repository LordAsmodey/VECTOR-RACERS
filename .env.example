# --- API (NestJS) ---
API_URL=http://localhost:3001
NODE_ENV=development

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Database (Prisma in packages/db) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vector_racers?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256) — paths to PEM files or inline base64 in prod tooling ---
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/jwt-access-public.pem
JWT_ACCESS_PRIVATE_KEY_PATH=./keys/jwt-access-private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=./keys/jwt-refresh-public.pem
JWT_REFRESH_PRIVATE_KEY_PATH=./keys/jwt-refresh-private.pem

# --- CORS (comma-separated origins for Nest) ---
CORS_ORIGINS=http://localhost:3000

# --- Metrics / ops ---
METRICS_TOKEN=change-me-in-production

# --- Stripe (optional / post-MVP) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
